# Preferred auth for retail paper/live watchlists: Cloud MCP OAuth
#   python manage_watchlist.py login
# Tokens stored in backend/conf/webull_mcp_tokens.json
#
# auth_mode is also in config/watchlist.json (default: mcp_oauth)
# WEBULL_AUTH_MODE=mcp_oauth
# WEBULL_MCP_URL=https://api.webull.com/mcp

# Optional: OpenAPI app-key path (only if auth_mode=openapi_sdk)
# WEBULL_APP_KEY=your_app_key
# WEBULL_APP_SECRET=your_app_secret
# WEBULL_ENVIRONMENT=uat
# WEBULL_REGION_ID=us

# Optional overrides
# WEBULL_WATCHLIST_ENABLED=true
# WEBULL_WATCHLIST_DRY_RUN=false
# WEBULL_WATCHLIST_NAME=Today's Gap'n'Go
