# Webull OpenAPI credentials (https://developer.webull.com/)
# Used to auto-add Gap'n'Go screener hits to "Today's Gap'n'Go" watchlist.
# Same operations as Cloud MCP tools: create_watchlist, add_watchlist_instruments, etc.

WEBULL_APP_KEY=your_app_key
WEBULL_APP_SECRET=your_app_secret
# Paper / test / sandbox OpenAPI app → uat  (host: api.sandbox.webull.com)
# Live production OpenAPI app        → prod (host: api.webull.com)
WEBULL_ENVIRONMENT=uat
WEBULL_REGION_ID=us

# Optional overrides
# WEBULL_WATCHLIST_ENABLED=true
# WEBULL_WATCHLIST_DRY_RUN=false
# WEBULL_WATCHLIST_NAME=Today's Gap'n'Go
